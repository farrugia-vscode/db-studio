{
  "name": "db-studio",
  "displayName": "DB Studio",
  "description": "PHPStorm-style database explorer: browse schema, run SQL, edit data (MySQL, MariaDB, PostgreSQL)",
  "version": "0.0.9",
  "publisher": "farrugia",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "build": "bun esbuild.ts",
    "watch": "bun esbuild.ts --watch",
    "check": "tsc -p . --noEmit && tsc -p src/webview --noEmit",
    "vscode:prepublish": "bun run build"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbStudio",
          "title": "DB Studio",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "dbStudio": [
        {
          "id": "dbStudio.explorer",
          "name": "Connections"
        }
      ]
    },
    "commands": [
      {
        "command": "dbStudio.addConnection",
        "title": "Add Connection",
        "icon": "$(add)",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.editConnection",
        "title": "Edit Connection",
        "icon": "$(edit)",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.removeConnection",
        "title": "Remove Connection",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.runQuery",
        "title": "Run SQL Query",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.openTableData",
        "title": "Open Table Data",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.showTableDdl",
        "title": "Show DDL",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.emptyTable",
        "title": "Empty Table…",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.dropTable",
        "title": "Drop Table…",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.createTable",
        "title": "New Table…",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.modifyTable",
        "title": "Modify Table…",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.createDatabase",
        "title": "New Database…",
        "category": "DB Studio"
      },
      {
        "command": "dbStudio.dropDatabase",
        "title": "Drop Database…",
        "category": "DB Studio"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbStudio.addConnection",
          "when": "view == dbStudio.explorer",
          "group": "navigation@1"
        },
        {
          "command": "dbStudio.refresh",
          "when": "view == dbStudio.explorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "dbStudio.runQuery",
          "when": "view == dbStudio.explorer && viewItem == connection",
          "group": "inline"
        },
        {
          "command": "dbStudio.createDatabase",
          "when": "view == dbStudio.explorer && viewItem == connection",
          "group": "0_new@1"
        },
        {
          "command": "dbStudio.editConnection",
          "when": "view == dbStudio.explorer && viewItem == connection",
          "group": "inline"
        },
        {
          "command": "dbStudio.editConnection",
          "when": "view == dbStudio.explorer && viewItem == connection",
          "group": "1_manage@1"
        },
        {
          "command": "dbStudio.removeConnection",
          "when": "view == dbStudio.explorer && viewItem == connection",
          "group": "1_manage@2"
        },
        {
          "command": "dbStudio.openTableData",
          "when": "view == dbStudio.explorer && viewItem == table",
          "group": "inline"
        },
        {
          "command": "dbStudio.createTable",
          "when": "view == dbStudio.explorer && viewItem == namespace",
          "group": "inline"
        },
        {
          "command": "dbStudio.createTable",
          "when": "view == dbStudio.explorer && viewItem == namespace",
          "group": "1_table@1"
        },
        {
          "command": "dbStudio.dropDatabase",
          "when": "view == dbStudio.explorer && viewItem == namespace",
          "group": "9_danger@1"
        },
        {
          "command": "dbStudio.modifyTable",
          "when": "view == dbStudio.explorer && viewItem == table",
          "group": "2_table@1"
        },
        {
          "command": "dbStudio.showTableDdl",
          "when": "view == dbStudio.explorer && viewItem == table",
          "group": "2_table@2"
        },
        {
          "command": "dbStudio.emptyTable",
          "when": "view == dbStudio.explorer && viewItem == table",
          "group": "9_danger@1"
        },
        {
          "command": "dbStudio.dropTable",
          "when": "view == dbStudio.explorer && viewItem == table",
          "group": "9_danger@2"
        }
      ]
    },
    "configuration": {
      "title": "DB Studio",
      "properties": {
        "dbStudio.connections": {
          "type": "array",
          "default": [],
          "description": "Saved database connections (passwords are stored separately in the OS secret storage).",
          "items": {
            "type": "object",
            "required": [
              "name",
              "driver",
              "host",
              "user"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "driver": {
                "type": "string",
                "enum": [
                  "mysql",
                  "postgres"
                ]
              },
              "host": {
                "type": "string"
              },
              "port": {
                "type": "number"
              },
              "user": {
                "type": "string"
              },
              "database": {
                "type": "string"
              },
              "color": {
                "type": "string",
                "description": "Optional hex color (e.g. #4ec94e) tinting the connection in the tree."
              }
            }
          }
        },
        "dbStudio.dateLocale": {
          "type": "string",
          "default": "",
          "description": "Locale for displaying date/time columns (e.g. fr-FR, en-US). Empty = raw value (YYYY-MM-DD HH:MM:SS)."
        }
      }
    }
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
